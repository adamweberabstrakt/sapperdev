# ─────────────────────────────────────────────────────────────────────────────
# Per-client env. Each client site is its own Netlify site with its own values.
# See docs/TENANCY-AND-PORTABILITY.md for the isolation model.
# ─────────────────────────────────────────────────────────────────────────────

# Sanity (optional). Leave unset and the site uses the static content in
# src/lib/blog.ts. Each CLIENT gets their OWN Sanity project — never a shared
# dataset — so set this to that client's project id to enable live editing.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Resend (only needed if a contact form posting to /api/contact is re-enabled)
RESEND_API_KEY=
