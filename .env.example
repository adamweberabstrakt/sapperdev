# Sanity (optional). Leave unset and the blog uses the static posts in
# src/lib/blog.ts. Set these to switch the blog to live Sanity content.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Resend (only needed if a contact form posting to /api/contact is re-enabled)
RESEND_API_KEY=
